# FIRE-PALANTIR 환경변수 설정
# 이 파일을 복사해 .env.local 로 저장하고 값을 입력하세요

# Supabase (https://app.supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Kakao Map (https://developers.kakao.com → 내 애플리케이션)
VITE_KAKAO_MAP_KEY=your-kakao-map-key-here

# ⚠️  아래 키들은 절대 VITE_ 접두사로 노출하지 마세요
# 반드시 Supabase Edge Function 환경변수로만 설정:
#
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-xxxxx
#   supabase secrets set KAKAO_REST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   supabase secrets set SAFEPASS_API_KEY=xxxxx          (SafePass 연동 시)
#   supabase secrets set APP_URL=https://fire-palantir.vercel.app
